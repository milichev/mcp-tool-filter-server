# =============================================================================
# mcp-tool-filter-server — environment variables
# =============================================================================

# ---------------------------------------------------------------------------
# Upstream MCP server
# The HTTP base URL of the anytype-mcp (or any MCP) server to proxy.
# Required.
# ---------------------------------------------------------------------------
UPSTREAM_MCP_TRANSPORT=http

# When UPSTREAM_MCP_TRANSPORT == http
UPSTREAM_MCP_URL=http://localhost:4041

# When UPSTREAM_MCP_TRANSPORT == stdio
UPSTREAM_MCP_COMMAND=npx
UPSTREAM_MCP_ARGS='-y,@anyproto/anytype-mcp'
UPSTREAM_MCP_ENV=ANYTYPE_API_BASE_URL:http://127.0.0.1:31009
UPSTREAM_MCP_CWD=

# ---------------------------------------------------------------------------
# Transport for THIS filter server
# stdio  — use when Claude Desktop or another MCP client spawns the process
# http   — use when running as a standalone container (e.g. in ToolHive)
# Default: stdio
# ---------------------------------------------------------------------------
PROXY_MCP_TRANSPORT=http

# Port to listen on when MCP_TRANSPORT=http
# Default: 3000
PROXY_MCP_PORT=3129

# ---------------------------------------------------------------------------
# Embedding provider
# local             — no API key needed, ~25 MB model download on first run
# openai            — requires EMBEDDING_API_KEY
# voyage / cohere   — requires EMBEDDING_API_KEY
# Default: local
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=local

# HuggingFace model name (local provider only)
# Default: Xenova/all-MiniLM-L6-v2
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Use quantized model for faster inference (local provider only)
# Default: true
# EMBEDDING_QUANTIZED=true

# API key (required for openai / voyage / cohere)
# EMBEDDING_API_KEY=sk-...

# Embedding dimensions (API providers only, optional)
# EMBEDDING_DIMENSIONS=384

# Custom base URL for embedding API (optional, e.g. for self-hosted endpoints)
# EMBEDDING_BASE_URL=https://api.openai.com

# ---------------------------------------------------------------------------
# Tool filter settings
# ---------------------------------------------------------------------------

# Maximum number of tools to return per request
# Default: 20
# FILTER_TOP_K=20

# Minimum similarity score threshold (0–1)
# Default: 0.3
# FILTER_MIN_SCORE=0.3

# Number of recent conversation messages used as context
# Default: 3
# FILTER_CONTEXT_MESSAGES=3

# Comma-separated tool names always included regardless of score
# FILTER_ALWAYS_INCLUDE=discover-spaces,API-list-spaces

# Comma-separated tool names never included
# FILTER_EXCLUDE=

# Maximum token count for context string
# Default: 500
# FILTER_MAX_CONTEXT_TOKENS=500

# Include server-level description in tool embeddings
# Helps with broad intent queries; hurts specific tool queries. Keep false.
# Default: false
# FILTER_INCLUDE_SERVER_DESCRIPTION=false

# Enable per-request timing logs to stderr
# Default: false
# FILTER_DEBUG=false

# ---------------------------------------------------------------------------
# Logging
# trace | debug | info | warn | error | silent
# Default: info
# ---------------------------------------------------------------------------
# LOG_LEVEL=info
