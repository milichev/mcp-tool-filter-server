{
  "name": "mcp-tool-filter-server",
  "version": "1.0.0",
  "description": "MCP proxy server with semantic tool filtering via mcp-tool-filter",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-tool-filter-server": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf bin build && tsc && node scripts/build-cli.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "tool-filter",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "esbuild-node-externals": "^1.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@portkey-ai/mcp-tool-filter": "^1.0.1",
    "zod": "^4.3.6"
  }
}
