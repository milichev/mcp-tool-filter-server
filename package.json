{
  "name": "mcp-tool-filter-server",
  "version": "1.0.0",
  "description": "MCP proxy server with semantic tool filtering via mcp-tool-filter",
  "type": "module",
  "main": "bin/mcp-tool-filter-server.mjs",
  "bin": {
    "mcp-tool-filter-server": "bin/mcp-tool-filter-server.mjs"
  },
  "exports": {
    ".": "./bin/mcp-tool-filter-server.mjs"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf bin build .cache",
    "build-cli": "node build-cli.js",
    "build": "npm run clean && tsc && npm run build-cli",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "mcp",
    "tool-filter",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@portkey-ai/mcp-tool-filter": "^1.0.1",
    "close-with-grace": "^2.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.4",
    "@vitest/coverage-v8": "^4.1.1",
    "esbuild": "^0.27.4",
    "esbuild-node-externals": "^1.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.1"
  }
}
